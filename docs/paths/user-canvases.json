{
  "/api/v1/users/me/canvas": {
    "get": {
      "summary": "Get all canvases for the current user",
      "security": [
        {
          "cookieAuth": []
        }
      ],
      "parameters": [
        {
          "name": "include_deleted",
          "in": "query",
          "schema": {
            "type": "boolean",
            "default": false
          },
          "description": "Controls if the response should include canvases that are soft deleted"
        }
      ],
      "responses": {
        "200": {
          "description": "All the canvases associated with the current user",
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "../schemas/canvas.json#/UserCanvas"
                }
              }
            }
          }
        },
        "400": {
          "description": "Bad Request",
          "content": {
            "application/json": {
              "schema": {
                "type": "string"
              }
            }
          }
        },
        "401": {
          "description": "Authentication Required"
        },
        "500": {
          "description": "Internal Server Error"
        }
      }
    },
    "post": {
      "summary": "Create a canvas for the current user",
      "security": [
        {
          "cookieAuth": []
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../schemas/canvas.json#/CreateCanvasRequest"
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Canvas successfully created",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../schemas/canvas.json#/UserCanvas"
              }
            }
          }
        },
        "400": {
          "description": "Initial canvas graph is malformed"
        },
        "401": {
          "description": "Authentication Required"
        },
        "500": {
          "description": "Internal Server Error"
        }
      }
    }
  },
  "/api/v1/users/me/canvas/{save_id}": {
    "put": {
      "summary": "Update properties of a canvas for the current user",
      "security": [
        {
          "cookieAuth": []
        }
      ],
      "parameters": [
        {
          "name": "save_id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "integer"
          },
          "description": "The Canvas Save ID"
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../schemas/canvas.json#/UpdateCanvasRequest"
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Canvas successfully updated",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../schemas/canvas.json#/UserCanvas"
              }
            }
          }
        },
        "400": {
          "description": "The update request is malformed"
        },
        "404": {
          "description": "The Canvas does not exist"
        },
        "401": {
          "description": "Authentication Required"
        },
        "500": {
          "description": "Internal Server Error"
        }
      }
    }
  },
  "/api/v1/users/me/canvas/trash": {
    "put": {
      "summary": "Trash a list of Canvas Save IDs for the current User",
      "security": [
        {
          "cookieAuth": []
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Canvases trashed successfully"
        },
        "400": {
          "description": "The request body is not a valid array of canvas IDs"
        },
        "401": {
          "description": "Authentication Required"
        },
        "500": {
          "description": "Internal Server Error"
        }
      }
    }
  },
  "/api/v1/users/me/canvas/restore": {
    "put": {
      "summary": "Restore a list of Canvas Save IDs for the current User",
      "security": [
        {
          "cookieAuth": []
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Canvases restored successfully"
        },
        "400": {
          "description": "The request body is not a valid array of canvas IDs"
        },
        "401": {
          "description": "Authentication Required"
        },
        "500": {
          "description": "Internal Server Error"
        }
      }
    }
  },
  "/api/v1/users/me/canvas/{save_id}/graph": {
    "get": {
      "summary": "Get the Nodes, Edges, and Tags for a Canvas",
      "security": [
        {
          "cookieAuth": []
        }
      ],
      "parameters": [
        {
          "name": "save_id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "integer"
          },
          "description": "The Canvas Save ID"
        },
        {
          "name": "include_deleted",
          "in": "query",
          "schema": {
            "type": "boolean",
            "default": false
          },
          "description": "Controls if the response should include soft deleted nodes, edges, and canvases"
        }
      ],
      "responses": {
        "200": {
          "description": "Graph data retrieved successfully",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../schemas/canvas.json#/CanvasGraph"
              }
            }
          }
        },
        "404": {
          "description": "The Canvas does not exist"
        },
        "401": {
          "description": "Authentication Required"
        },
        "500": {
          "description": "Internal Server Error"
        }
      }
    },
    "post": {
      "summary": "Submit a graph to merge into a Canvas",
      "security": [
        {
          "cookieAuth": []
        }
      ],
      "parameters": [
        {
          "name": "save_id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "integer"
          },
          "description": "The Canvas Save ID"
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../schemas/canvas.json#/Graph"
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "The resulting Canvas graph after the merge",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../schemas/canvas.json#/CanvasGraph"
              }
            }
          }
        },
        "400": {
          "description": "The submitted graph is malformed"
        },
        "404": {
          "description": "The Canvas does not exist"
        },
        "401": {
          "description": "Authentication Required"
        },
        "500": {
          "description": "Internal Server Error"
        }
      }
    }
  },
  "/api/v1/users/me/canvas/{save_id}/graph/trash": {
    "put": {
      "summary": "Soft delete Nodes and Edges from a Canvas",
      "description": "Soft deletes the listed Canvas Nodes and Edges. Soft deleting a node also soft deletes every edge attached to it. Returns the resulting Canvas graph.",
      "security": [
        {
          "cookieAuth": []
        }
      ],
      "parameters": [
        {
          "name": "save_id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "integer"
          },
          "description": "The Canvas Save ID"
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../schemas/canvas.json#/GraphSelection"
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "The resulting Canvas graph after the soft delete",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../schemas/canvas.json#/CanvasGraph"
              }
            }
          }
        },
        "400": {
          "description": "The request body is not a valid selection of node and edge ids"
        },
        "404": {
          "description": "The Canvas does not exist"
        },
        "401": {
          "description": "Authentication Required"
        },
        "500": {
          "description": "Internal Server Error"
        }
      }
    }
  },
  "/api/v1/users/me/canvas/{save_id}/graph/restore": {
    "put": {
      "summary": "Restore soft deleted Nodes and Edges in a Canvas",
      "description": "Restores the listed Canvas Nodes and Edges. An edge is only restored if both of its endpoint nodes are active. Returns the resulting Canvas graph.",
      "security": [
        {
          "cookieAuth": []
        }
      ],
      "parameters": [
        {
          "name": "save_id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "integer"
          },
          "description": "The Canvas Save ID"
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../schemas/canvas.json#/GraphSelection"
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "The resulting Canvas graph after the restore",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../schemas/canvas.json#/CanvasGraph"
              }
            }
          }
        },
        "400": {
          "description": "The request body is not a valid selection of node and edge ids"
        },
        "404": {
          "description": "The Canvas does not exist"
        },
        "401": {
          "description": "Authentication Required"
        },
        "500": {
          "description": "Internal Server Error"
        }
      }
    }
  },
  "/api/v1/users/me/canvas/{save_id}/node/{data_id}": {
    "get": {
      "summary": "Get the underlying data entity for a Canvas Node",
      "security": [
        {
          "cookieAuth": []
        }
      ],
      "parameters": [
        {
          "name": "save_id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "integer"
          },
          "description": "The Canvas Save ID"
        },
        {
          "name": "data_id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "integer"
          },
          "description": "The Data Node ID (the data_id of the Canvas Node)"
        }
      ],
      "responses": {
        "200": {
          "description": "The underlying data entity for the node",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../schemas/summary.json#/SummaryNode"
              }
            }
          }
        },
        "404": {
          "description": "No node with the given data_id exists"
        },
        "401": {
          "description": "Authentication Required"
        },
        "500": {
          "description": "Internal Server Error"
        }
      }
    }
  },
  "/api/v1/users/me/canvas/{save_id}/edge/{data_id}": {
    "get": {
      "summary": "Get the underlying data entity for a Canvas Edge",
      "security": [
        {
          "cookieAuth": []
        }
      ],
      "parameters": [
        {
          "name": "save_id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "integer"
          },
          "description": "The Canvas Save ID"
        },
        {
          "name": "data_id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "integer"
          },
          "description": "The Data Edge ID (the data_id of the Canvas Edge)"
        }
      ],
      "responses": {
        "200": {
          "description": "The underlying data entity for the edge",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../schemas/summary.json#/SummaryEdge"
              }
            }
          }
        },
        "404": {
          "description": "No edge with the given data_id exists"
        },
        "401": {
          "description": "Authentication Required"
        },
        "500": {
          "description": "Internal Server Error"
        }
      }
    }
  }
}
